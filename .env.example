APP_PORT=8095
APP_NAME=Kairix Opsbook
OPSBOOK_IMAGE_TAG=0.1.17
APP_VERSION=0.1.17
INSTANCE_NAME=Opsbook
INSTANCE_MODE=primary

POSTGRES_DB=opsbook
POSTGRES_USER=opsbook
POSTGRES_PASSWORD=change-this-database-password
DATABASE_URL=postgresql+psycopg://opsbook:change-this-database-password@db:5432/opsbook

# Change both before storing real credentials. They may be passphrases;
# Opsbook derives Fernet keys from them.
OPSBOOK_SECRET_KEY=change-this-secret-encryption-key
EXPORT_SECRET_KEY=change-this-export-encryption-key
SESSION_SECRET_KEY=change-this-session-signing-key
OPSBOOK_AGENT_TOKEN=change-this-agent-token

# Set true only when served over HTTPS or a trusted reverse proxy.
SESSION_COOKIE_SECURE=false
SESSION_TIMEOUT_MINUTES=20
MEDIUM_UNLOCK_MINUTES=5

EXPORT_DIR=/app/exports
BACKUP_DIR=/app/backups
